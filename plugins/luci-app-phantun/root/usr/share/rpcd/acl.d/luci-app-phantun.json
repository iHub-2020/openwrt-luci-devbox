{
  "luci-app-phantun": {
    "description": "Grant access to Phantun configuration and status",
    "read": {
      "uci": [
        "phantun"
      ],
      "file": {
        "/usr/bin/phantun_client": [
          "read",
          "exec"
        ],
        "/usr/bin/phantun_server": [
          "read",
          "exec"
        ],
        "/etc/config/phantun": [
          "read"
        ],
        "/bin/sh": [
          "exec"
        ]
      },
      "ubus": {
        "service": [
          "list"
        ],
        "file": [
          "exec",
          "stat",
          "read",
          "list"
        ]
      }
    },
    "write": {
      "uci": [
        "phantun"
      ]
    }
  }
}
