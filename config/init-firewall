#!/bin/sh
# ==============================================================
#  config/init-firewall — 防火墙额外规则初始化
#  entrypoint.sh 会在启动时将此文件复制到容器内执行
#  用于补充 UCI firewall 无法覆盖的底层 iptables/nftables 规则
# ==============================================================

# WireGuard 流量标记（供伪装插件测试 fwmark/policy routing）
ip rule add fwmark 51820 table 51820 2>/dev/null || true
ip route add default dev wg0 table 51820 2>/dev/null || true

# 允许已建立/相关连接（容器内基本安全规则）
iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || true
iptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || true

# IPv6 基本规则
ip6tables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || true

echo "[firewall] 额外规则已应用"
